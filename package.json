{
  "name": "stripe2zohobooks",
  "version": "0.1.0",
  "description": "Sync multiple Stripe accounts to Zoho Books",
  "type": "module",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "setup": "tsx src/cli.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "test": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@inquirer/prompts": "^8.3.2",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.6.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "stripe": "^17.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "@biomejs/biome",
      "esbuild"
    ]
  }
}