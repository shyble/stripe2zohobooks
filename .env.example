# Server
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Database
DATABASE_PATH=./data/stripe2zoho.db

# Security
ADMIN_PASSWORD=changeme
ENCRYPTION_KEY=  # 32-byte hex string for encrypting API keys at rest

# Sync Mode: "poll" (default) or "webhook"
# Poll mode fetches events from Stripe API on an interval — no public URL needed
# Webhook mode requires Stripe to push events to your server
SYNC_MODE=poll
POLL_INTERVAL_SECONDS=600

# Zoho OAuth
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=
ZOHO_API_DOMAIN=https://www.zohoapis.com

# Zoho Usage Limits (override for paid plans)
# ZOHO_DAILY_API_LIMIT=1000
# ZOHO_YEARLY_INVOICE_LIMIT=1000
